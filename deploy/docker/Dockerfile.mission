FROM golang:1.26-alpine AS builder
RUN apk add --no-cache git ca-certificates
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /usr/local/bin/aman .

FROM alpine:3.21
RUN apk add --no-cache bash jq coreutils
COPY --from=builder /usr/local/bin/aman /usr/local/bin/aman
COPY missions/ /missions/
RUN chmod +x /missions/*.sh
WORKDIR /
CMD ["/missions/run-all.sh"]
